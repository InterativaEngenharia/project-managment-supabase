# Copie para .env e preencha com os valores reais (nunca commitar o .env preenchido).

# Painel Supabase -> Project Settings -> API
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Painel Supabase -> Project Settings -> Database -> Connection string ->
# Connection Pooling (modo "Transaction", porta 6543). Use o pooler, não a
# conexão direta (db.<projeto>.supabase.co:5432) - confirmado nesta migração
# que a conexão direta só resolve em IPv6, e isso quebra em qualquer rede
# IPv4-only (inclusive onde este backend pode acabar rodando).
#
# ?pgbouncer=true é obrigatório em modo Transaction - avisa o Prisma pra não
# usar prepared statements, que o PgBouncer nesse modo não suporta.
#
# Por que Transaction e não Session: o pooler em modo "Session" tem um teto
# GLOBAL de 15 conexões simultâneas (todos os clientes somados, de todo
# mundo) - rodando o backend local + a Railway ao mesmo tempo já é o
# suficiente pra estourar os 15 e travar toda conexão nova (erro
# EMAXCONNSESSION), inclusive pra quem só quer consultar o banco direto.
# Confirmado ao vivo nesta sessão: Transaction mode aguenta 25+ queries
# concorrentes sem esse problema.
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[SENHA]@aws-0-[REGIAO].pooler.supabase.com:6543/postgres?pgbouncer=true

PORT=3001
# Em produção (Railway), aponte pro domínio real do frontend na Vercel, não
# localhost - e não use "*", senão as rotas autenticadas com cookies/credenciais
# ficam abertas pra qualquer origem.
CORS_ORIGIN=http://localhost:5173

# Railway seta isso automaticamente pra "production" - só precisa declarar
# manualmente rodando em outro lugar. Controla duas coisas em src/config:
# desliga o Swagger UI (/docs) e ajusta o log de startup.
NODE_ENV=development
