# Copie para .env e preencha com os valores reais (nunca commitar o .env preenchido).

# Painel Supabase -> Project Settings -> API
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Painel Supabase -> Project Settings -> Database -> Connection string
# Se a conexão direta (db.<projeto>.supabase.co:5432) falhar com erro de
# rede/DNS, use a Connection Pooling string (host aws-0-<regiao>.pooler.supabase.com)
# - muitas redes só têm saída IPv4 e a conexão direta do Supabase é IPv6-only.
DATABASE_URL=postgresql://postgres:[SENHA]@db.seu-projeto.supabase.co:5432/postgres

PORT=3001
CORS_ORIGIN=http://localhost:5173
