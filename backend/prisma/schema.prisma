// Modelos escritos à mão a partir das colunas reais observadas em um dump
// do banco (COPY public."Disciplina" (...)), porque a introspecção via
// `npx prisma db pull` não pôde ser validada neste ambiente (a conexão
// direta db.<project>.supabase.co só resolve em IPv6). Tipos e nullability
// são melhor esforço — rode `npm run prisma:pull` numa rede com acesso ao
// Postgres (direto ou via connection pooler) para confirmar/completar antes
// de confiar neste schema em produção. Ao migrar um novo módulo, prefira
// sempre rodar a introspecção real em vez de copiar este padrão às cegas.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Disciplina {
  id             String    @id
  nome           String
  cor            String?
  icone          String?
  // Tipo real incerto sem introspecção (jsonb vs text[]) - confirmar via db pull.
  codisciplinas  Json?
  ordem          Int?
  created_date   DateTime?
  updated_date   DateTime?
  created_by_id  String?
  created_by     String?
  is_sample      Boolean?

  @@map("Disciplina")
}

// Colunas confirmadas via CREATE TABLE public."Usuario" real (não é um schema
// de melhor esforço como o de Disciplina acima). Não existe coluna "role" -
// só "perfil". O middleware de auth não deve mais referenciar "role".
model Usuario {
  id                             String    @id
  nome                           String?
  email                          String?
  email_notificacao              String?
  cargo                          String?
  departamento                   String?
  equipe_id                      String?
  telefone                       String?
  data_admissao                  String?
  status                         String?   @default("ativo")
  perfil                         String?   @default("user")
  usuarios_permitidos_visualizar Json?
  created_date                   DateTime?
  updated_date                   DateTime?
  created_by_id                  String?
  created_by                     String?
  is_sample                      Boolean?  @default(false)

  @@map("Usuario")
}