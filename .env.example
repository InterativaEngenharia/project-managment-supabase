# Copie para .env (ou .env.local) e preencha - nunca commitar com valores reais.

# Painel Supabase -> Project Settings -> API
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=

# URL do backend Node/Fastify (ver pasta backend/). Em produção, aponta para
# onde o backend estiver hospedado (Railway/Render/etc), não para localhost.
VITE_BACKEND_URL=http://localhost:3001
